# Sentinel Orchestrator 環境變數
# 在 Vercel Settings → Environment Variables 設定

NEXT_PUBLIC_GEMINI_KEY=your_gemini_key_here
NEXT_PUBLIC_GROK_KEY=your_grok_key_here
NEXT_PUBLIC_PERPLEXITY_KEY=your_perplexity_key_here
NEXT_PUBLIC_OPENAI_KEY=your_openai_key_here
